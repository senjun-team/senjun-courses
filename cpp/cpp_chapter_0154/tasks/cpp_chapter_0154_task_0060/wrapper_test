import boost.ut;

import std;

struct ListNode
{
public:
    ListNode() {
        ++counter;
    }

    explicit ListNode(int value) : val(value) 
    {
        ++counter;
    }

    ~ListNode()
    {
        --counter;
    }
    
    static int get_counter()
    {
        return counter;
    }

    explicit ListNode(int value, ListNode * next_node) 
    : val(value), next(next_node) {}
    
    int val = 0;
    ListNode * next = nullptr;

private:
    static int counter;
};

int ListNode::counter = 0;

class List
{
public:
    List() = default;
    ~List();

    std::size_t len();
    void push_front(int val);
    bool remove(int val);
    ListNode * get(std::size_t index);

private:
    ListNode * head = nullptr;
    std::size_t size = 0;
};

