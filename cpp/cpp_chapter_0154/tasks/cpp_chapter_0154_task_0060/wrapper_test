void check_push_scenario(const std::vector<int> & values)
{
    const int count_start = ListNode::get_counter(); 

    List lst;
    expect(lst.len() == 0) << "len() of empty List must be 0" << fatal;

    for(std::size_t i = 0; i < values.size(); ++i)
    {
        lst.push_front(values[i]);
        expect(lst.len() == i + 1) << std::format("len() of List after {} calls to push_front() must be {}",
                                                    i + 1, i + 1) << fatal;
    }

    const int count_end = ListNode::get_counter();

    expect(count_end == count_start + values.size()) << std::format("Called push_front for values: {}. {} ListNode objects must be created",
                                    values, values.size()) << fatal;

    
    std::vector<int> dst(values.size());
    std::reverse_copy(std::begin(values), std::end(values), std::begin(dst));

    for (std::size_t i = 0; i < dst.size(); ++i)
    {
        expect(lst.get(i)->val == dst[i]) << std::format(
                               "Called push_front for values: {}. {}-th node must be equal to {}. But its value is {}",
                               values, i, dst[i], lst.get(i)->val) << fatal;
    }
}


struct TestNode
{
    int val = 0;
    bool to_delete = false;
    bool exists = false;
};

struct TestCaseRem
{
    std::vector<TestNode> actions;
    std::vector<std::vector<int>> states;
};


std::string get_test_description(const TestCaseRem & c)
{
    std::string s = "Test case:\nCreated list.\n";
    for (const TestNode & act: c.actions)
    {
        s += std::format("Called {}({})\n", act.to_delete ? "remove" : "push_front", act.val);
    }

    return s;
}

void check_remove_scenario(const TestCaseRem & c)
{
    if (c.actions.size() != c.states.size())
        throw std::logic_error("Error in test data");

    const int count_start = ListNode::get_counter(); 

    {
        List lst;

        for (std::size_t i = 0; i < c.actions.size(); ++i)
        {
            const TestNode & act = c.actions[i];

            if (act.to_delete)
            {
                const bool removed = lst.remove(act.val);
                expect(removed == act.exists) << std::format("remove({}) returned {}. Expected result: {}.\n{}",
                                                      act.val, removed, act.exists, get_test_description(c)) << fatal;
            }
            else
            {
                lst.push_front(act.val);
            }

            expect(lst.len() == c.states[i].size()) << std::format("len() returned {}. Expected result: {}.\n{}",
                                        lst.len(), c.states[i].size(), get_test_description(c)) << fatal;

            for (std::size_t j = 0; j < c.states[i].size(); ++j)
            {
                expect(lst.get(j)->val == c.states[i][j]) << std::format(
                                    "{}-th node must be equal to {}. But its value is {}.\n",
                                    j, c.states[i][j],lst.get(j)->val, get_test_description(c)) << fatal;
            }
            
        }
    }

    expect(count_start == ListNode::get_counter()) << std::format("Check method remove() for memory leak.\n{}",
                                                      get_test_description(c)) << fatal;
}

