#define RECV_TABLE_SIZE 256

typedef enum e_direction
{
    no_direction = 0,
    forward_only = 1,
    backward_only = 2,
    both_directions = 3
} direction_t;


#define DEF_ARRAY_TYPE(type) \
struct s_pattern_##type \
{ \
    type * array; \
    size_t size; \
}

typedef DEF_ARRAY_TYPE(void) generic_array_t;
typedef DEF_ARRAY_TYPE(uint8_t) byte_array_t;
typedef DEF_ARRAY_TYPE(size_t) size_array_t;


typedef struct s_recv_param
{
    // адрес псевдоисточника (по факту ключ)
    const char * addr;
    // данные для передачи
    generic_array_t data;
    // номер сегмента с которого начинается передача данных
    size_t start_sgm;
    // частота сбоев
    size_t skip_rate;
    // паттерн процентов размеров серии сегментов
    // значения должны быть в диапазоне 1..199
    // значение 0 является признаком конца серии
    // сумма серии должна быть равна 100 * N, где N - длина серии
    byte_array_t pattern;
} recv_param_t;


typedef struct s_recv_table
{
    recv_param_t items[RECV_TABLE_SIZE];
} recv_table_t;

typedef struct s_bound
{
    size_t idx;
    size_t pos;
} bound_t;

typedef struct s_recv_desc_impl
{
    // адрес псевдоисточника (по факту ключ)
    const char * addr;
    // данные для передачи (внешнее владение)
    generic_array_t data;
    // максимальный размер сегмента
    size_t sgm_size;
    // общее количество сегментов для отправки
    size_t sgm_total;
    // номер сегмента и позиция при обратном итерировании
    bound_t to_begin;
    // номер сегмента и позиция при прямом итерировании
    bound_t to_end;
    // номер шага
    size_t step;
    // частота пропусков, когда recv_sgm() возвращает err_wait_for_data
    size_t skip_rate;
    // паттерн размеров серии сегментов
    // значение 0 является признаком конца серии
    size_array_t pattern;
} recv_desc_impl_t;

recv_table_t q_table;


// закрытая часть API

static recv_param_t * find_channel(const char* addr)
{
    recv_param_t* found = NULL;
    assert(addr != NULL);

    for (size_t i = 0; i < RECV_TABLE_SIZE; ++i)
    {
        recv_param_t* cur = &q_table.items[i];
        if (cur->addr != NULL && strcmp(addr, cur->addr) == 0)
        {
            found = cur;
            break;
        }
    }

    return found;
}

static recv_param_t * find_unused_channel(const char* addr)
{
    recv_param_t * found = NULL;
    assert(addr != NULL);

    for (size_t i = 0; i < RECV_TABLE_SIZE; ++i)
    {
        recv_param_t * cur = &q_table.items[i];
        if (cur->addr != NULL && strcmp(addr, cur->addr) == 0)
        {
            found = NULL;
            break;
        }

        if (cur->addr == NULL && found == NULL)
            found = cur;
    }

    return found;
}

static bool check_pattern(const uint8_t * pattern, size_t * size)
{
    assert(size != NULL);

    size_t sum = 0;
    *size = 0;

    if (pattern == NULL)
        return true;

    for (const uint8_t * item = pattern; *item != 0; ++item)
    {
        if (*item > 199)
            return false;

        sum += *item;
        ++*size;
    }

    return sum == 100 * *size;
}

int reserve_recv_channel(
    const char * addr,
    const void * data,
    size_t size,
    size_t start,
    size_t skip,
    const uint8_t * pattern)
{
    char * addr_copy = NULL;
    uint8_t * pattern_copy = NULL;
    void * data_copy = NULL;
    recv_param_t * unused = NULL;
    size_t pattern_size = 0;

    if (addr == NULL || data == NULL || size == 0)
        return err_bad_param;
    
    unused = find_unused_channel(addr);
    if (unused == NULL)
        return err_no_memory;

    if (!check_pattern(pattern, &pattern_size))
        return err_bad_param;

    addr_copy = strdup(addr);
    if (addr_copy == NULL)
        return err_no_memory;

    if (pattern_size > 0)
    {
        pattern_copy = (uint8_t *)malloc(sizeof(uint8_t) * pattern_size);

        if (pattern_copy == NULL)
        {
            free(addr_copy);
            return err_no_memory;
        }
        memcpy(pattern_copy, pattern, sizeof(uint8_t) * pattern_size);
    }

    data_copy = malloc(size);
    if (data_copy == NULL)
    {
        free(addr_copy);
        free(pattern_copy);
        return err_no_memory;
    }
    memcpy(data_copy, data, size);

    unused->addr = addr_copy;
    unused->data = (generic_array_t){ data_copy, size };
    unused->start_sgm = start;
    unused->skip_rate = skip;
    unused->pattern = (byte_array_t){ pattern_copy, pattern_size };

    return 0;
}

void free_recv_channel(const char * addr)
{
    recv_param_t * found = NULL;
    if (addr == NULL)
        return;

    found = find_channel(addr);
    if (found == NULL)
        return;

    free((char *)found->addr);
    free(found->data.array);
    free(found->pattern.array);

    found->addr = NULL;
    found->data = (generic_array_t){ NULL, 0 };
    found->start_sgm = 0;
    found->skip_rate = 0;
    found->pattern = (byte_array_t){ NULL, 0 };
}

inline static size_t sgm_count(size_t data_size, size_t sgm_size)
{
    return data_size / sgm_size + (data_size % sgm_size > 0 ? 1 : 0);
}

static direction_t possible_directions(const recv_desc_impl_t * dimpl)
{
    assert(dimpl != NULL);

    bool can_forward = dimpl->to_end.pos < dimpl->data.size;
    bool can_backward = dimpl->to_begin.pos > 0;

    if (can_forward && can_backward)
        return both_directions;

    if (can_forward)
        return forward_only;

    if (can_backward)
        return backward_only;

    return no_direction;
}

static direction_t choose_direction(const recv_desc_impl_t * dimpl)
{
    direction_t possible = possible_directions(dimpl);
    assert(possible == both_directions || possible == forward_only
        || possible == backward_only || possible == no_direction);

    if (possible == both_directions)
    {
        if (dimpl->step % 2 == 0)
            return forward_only;

        return backward_only;
    }

    return possible;
}

inline static int need_skip(const recv_desc_impl_t * dimpl)
{
    assert(dimpl != NULL);
    return dimpl->skip_rate > 1 && dimpl->step % dimpl->skip_rate == 0;
}

inline static const void * get_sgm_at(const recv_desc_impl_t * dimpl, size_t sgm_pos)
{
    assert(dimpl != NULL && sgm_pos < dimpl->data.size);
    return (const char *)dimpl->data.array + sgm_pos;
}

inline static const size_t base_sgm_size(size_t sgm_size, bool has_pattern)
{
    return has_pattern ? (size_t)llround((double)sgm_size / 2.0) : sgm_size;
}

inline static bool has_pattern(size_array_t pattern)
{
    return pattern.array != NULL && pattern.size > 0;
}

static const size_t sgm_size_to_begin(const recv_desc_impl_t * dimpl)
{
    assert(dimpl != NULL);
    const bool pattern_flag = has_pattern(dimpl->pattern);
    const size_t base_size = base_sgm_size(dimpl->sgm_size, pattern_flag);
    size_t size_to_begin = 0;
    size_t idx = 0;
    size_t pos = 0;

    if (dimpl->to_begin.pos == 0 || dimpl->to_begin.idx == 0)
        return size_to_begin;

    idx = dimpl->to_begin.idx - 1;
    pos = idx * base_size;
    size_to_begin = base_size;

    if (pattern_flag)
    {
        const size_t pattern_size = dimpl->pattern.size * base_size;
        const size_t repetitions = dimpl->data.size / pattern_size;

        if (idx < repetitions * dimpl->pattern.size)
        {
            const size_t count = idx / dimpl->pattern.size;
            const size_t rem = idx % dimpl->pattern.size;

            pos = count * pattern_size;
            for (size_t i = 0; i < rem; ++i)
                pos += dimpl->pattern.array[i];

            size_to_begin = dimpl->pattern.array[rem];
        }
    }

    size_to_begin = pos + size_to_begin < dimpl->to_begin.pos 
        ? size_to_begin : dimpl->to_begin.pos - pos;

    return size_to_begin;
}

static const size_t sgm_size_to_end(const recv_desc_impl_t * dimpl)
{
    assert(dimpl != NULL);
    const bool pattern_flag = has_pattern(dimpl->pattern);
    const size_t base_size = base_sgm_size(dimpl->sgm_size, pattern_flag);
    const size_t tail = dimpl->data.size - dimpl->to_end.pos;
    size_t size_to_end = 0;

    if (dimpl->to_end.pos >= dimpl->data.size || dimpl->to_end.idx >= dimpl->sgm_total)
        return size_to_end;

    size_to_end = base_size;
    if (pattern_flag)
    {
        const size_t pattern_size = base_size * dimpl->pattern.size;
        const size_t repetitions = dimpl->data.size / pattern_size;

        if (dimpl->to_end.idx < repetitions * dimpl->pattern.size)
            size_to_end = dimpl->pattern.array[dimpl->to_end.idx % dimpl->pattern.size];
    }

    size_to_end = tail < size_to_end ? tail : size_to_end;

    return size_to_end;
}

static bool make_pattern(byte_array_t pattern_def, size_t sgm_size, size_array_t * pattern)
{
    assert(pattern != NULL);

    const size_t base_size = base_sgm_size(sgm_size, pattern_def.array != NULL);
    size_t total = pattern_def.size * sgm_size;
    size_t sum = 0;

    // паттерн не определён либо размер сегмента слишком мал либо размер сегмента и паттерна нечётные
    if (pattern_def.array == NULL || pattern_def.size == 0 || base_size == 0 || total % 2 != 0)
        return true;

    // Условие вида `i + 1 < pattern_def.size` нужно для подавления 'Warning C6386: Buffer overrun'
    for (size_t i = 0; i + 1 < pattern_def.size; ++i)
    {
        size_t item_size = base_size * pattern_def.array[i] / 100;

        // паттерн не применим из-за слишком малого размера сегмента
        if (item_size == 0)
            return true;

        sum += item_size;
    }

    total /= 2;

    // паттерн не применим, игнор паттерна
    if (total <= sum || total > sum + sgm_size)
        return true;

    pattern->array = (size_t *)malloc(sizeof(size_t) * pattern_def.size);

    if (pattern->array == NULL)
        return false;

    pattern->size = pattern_def.size;

    for (size_t i = 0; i + 1 < pattern->size; ++i)
        pattern->array[i] = base_size * pattern_def.array[i] / 100;

    pattern->array[pattern->size - 1] = total - sum;

    return true;
}

static bound_t calc_start_bound(
    size_array_t pattern, size_t data_size, size_t base_size, size_t start_idx, size_t total)
{
    bound_t start_bound = { 0, 0 };

    if (start_idx >= total)
    {
        start_bound = (bound_t){ total, data_size };
        return start_bound;
    }

    if (has_pattern(pattern))
    {
        const size_t pattern_size = pattern.size * base_size;
        const size_t pattern_space = data_size - data_size % pattern_size;

        if (start_idx * base_size < pattern_space)
        {
            const size_t count = start_idx / pattern.size;
            const size_t rem = start_idx % pattern.size;
            start_bound.idx = start_idx;
            start_bound.pos = count * pattern_size;
            for (size_t i = 0; i < rem; ++i)
                start_bound.pos += pattern.array[i];

            return start_bound;
        }
    }

    start_bound = (bound_t){ start_idx, start_idx * base_size };
    return start_bound;
}

// открытая часть API
int open_recv(const char * addr, size_t sgm_size, recv_desc_t * pdesc)
{
    recv_desc_impl_t * dimpl = NULL;
    recv_param_t * found = NULL;
    size_array_t pattern = { NULL, 0 };
    bound_t start_bound = {0, 0};
    size_t total = 0;
    size_t base_size = 0;

    if (addr == NULL || sgm_size == 0 || pdesc == NULL)
        return err_bad_param;

    found = find_channel(addr);
    if (found == NULL)
        return err_address_unreachable;

    dimpl = (recv_desc_impl_t *)malloc(sizeof(recv_desc_impl_t));

    if (dimpl == NULL)
        return err_no_memory;

    if (!make_pattern(found->pattern, sgm_size, &pattern))
    {
        free(dimpl);
        return err_no_memory;
    }

    base_size = base_sgm_size(sgm_size, has_pattern(pattern));
    total = sgm_count(found->data.size, base_size);
    start_bound = calc_start_bound(pattern, found->data.size, base_size, found->start_sgm, total);

    dimpl->addr = found->addr;
    dimpl->data = found->data;
    dimpl->sgm_size = sgm_size;
    dimpl->sgm_total = total;
    dimpl->to_begin = start_bound;
    dimpl->to_end = start_bound;
    dimpl->step = 0;
    dimpl->skip_rate = found->skip_rate;
    dimpl->pattern = pattern;

    *pdesc = dimpl;
    return 0;
}

void close_recv(recv_desc_t * pdesc)
{
    if (pdesc != NULL)
        free(*pdesc);
}

size_t sgm_left(recv_desc_t desc)
{
    const recv_desc_impl_t* dimpl = (const recv_desc_impl_t *)desc;
    return desc == NULL ? 0 : dimpl->sgm_total - (dimpl->to_end.idx - dimpl->to_begin.idx);
}

size_t max_sgm_size(recv_desc_t desc)
{
    return desc == NULL ? 0 : ((recv_desc_impl_t *)desc)->sgm_size;
}

const char * recv_addr(recv_desc_t desc)
{
    return desc == NULL ? NULL : ((recv_desc_impl_t*)desc)->addr;
}

int recv_sgm(recv_desc_t desc, size_t * idx, void * buf, size_t * size)
{
    recv_desc_impl_t * dimpl = NULL;
    const void * sgm = NULL;
    size_t sgm_size = 0;
    direction_t direction = no_direction;

    if (desc == NULL || idx == NULL || size == NULL)
        return err_bad_param;

    dimpl = (recv_desc_impl_t *)desc;

    if (sgm_left(dimpl) == 0)
        return err_no_more_data;

    if (need_skip(dimpl))
    {
        ++dimpl->step;
        return err_wait_for_data;
    }

    direction = choose_direction(dimpl);
    if (direction == no_direction)
        return err_no_more_data;

    assert(direction == forward_only || direction == backward_only);
    if (direction == forward_only)
    {
        sgm_size = sgm_size_to_end(dimpl);
        if (sgm_size == 0)
            return err_internal;

        *idx = dimpl->to_end.idx;

        assert(dimpl->to_end.pos + sgm_size <= dimpl->data.size);
        sgm = get_sgm_at(dimpl, dimpl->to_end.pos);

        if (sgm_size > *size)
        {
            *size = sgm_size;
            return err_insufficient_buffer;
        }

        if (buf == NULL)
            return err_bad_param;

        dimpl->to_end.pos += sgm_size;
        ++dimpl->to_end.idx;
    }
    else
    {
        sgm_size = sgm_size_to_begin(dimpl);
        if (sgm_size == 0)
            return err_internal;

        assert(dimpl->to_begin.idx > 0);
        *idx = dimpl->to_begin.idx - 1;

        assert(sgm_size <= dimpl->to_begin.pos);
        sgm = get_sgm_at(dimpl, dimpl->to_begin.pos - sgm_size);

        if (sgm_size > *size)
        {
            *size = sgm_size;
            return err_insufficient_buffer;
        }

        if (buf == NULL)
            return err_bad_param;

        dimpl->to_begin.pos -= sgm_size;
        --dimpl->to_begin.idx;
    }

    memcpy(buf, sgm, sgm_size);
    *size = sgm_size;
    ++dimpl->step;

    return 0;
}

