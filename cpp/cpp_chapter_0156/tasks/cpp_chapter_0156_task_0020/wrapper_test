#define RECV_TABLE_SIZE 256

typedef enum e_direction
{
    no_direction = 0,
    forward_only = 1,
    backward_only = 2,
    both_directions = 3
} direction_t;


#define DEF_ARRAY_TYPE(type) \
struct s_pattern_##type \
{ \
    type * array; \
    size_t size; \
}

typedef DEF_ARRAY_TYPE(void) generic_array_t;
typedef DEF_ARRAY_TYPE(uint8_t) byte_array_t;
typedef DEF_ARRAY_TYPE(size_t) size_array_t;


typedef struct s_recv_param
{
    // адрес псевдоисточника (по факту ключ)
    const char * addr;
    // данные для передачи
    generic_array_t data;
    // номер сегмента с которого начинается передача данных
    size_t start_sgm;
    // частота сбоев
    size_t skip_rate;
    // паттерн процентов размеров серии сегментов
    // значения должны быть в диапазоне 1..199
    // значение 0 является признаком конца серии
    // сумма серии должна быть равна 100 * N, где N - длина серии
    byte_array_t pattern;
} recv_param_t;


typedef struct s_recv_table
{
    recv_param_t items[RECV_TABLE_SIZE];
} recv_table_t;

typedef struct s_bound
{
    size_t idx;
    size_t pos;
} bound_t;

typedef struct s_recv_desc_impl
{
    // адрес псевдоисточника (по факту ключ)
    const char * addr;
    // данные для передачи (внешнее владение)
    generic_array_t data;
    // максимальный размер сегмента
    size_t sgm_size;
    // общее количество сегментов для отправки
    size_t sgm_total;
    // номер сегмента и позиция при обратном итерировании
    bound_t to_begin;
    // номер сегмента и позиция при прямом итерировании
    bound_t to_end;
    // номер шага
    size_t step;
    // частота пропусков, когда recv_sgm() возвращает err_wait_for_data
    size_t skip_rate;
    // паттерн размеров серии сегментов
    // значение 0 является признаком конца серии
    size_array_t pattern;
} recv_desc_impl_t;

recv_table_t q_table;


