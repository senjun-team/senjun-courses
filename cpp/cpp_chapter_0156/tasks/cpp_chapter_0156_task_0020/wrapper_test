        std::string addr,
        C data,
        std::size_t start,
        std::size_t skip,
        const std::vector<std::uint8_t> & pattern);
    ~ChannelGuard();

    ChannelGuard(const ChannelGuard &) = delete;
    ChannelGuard & operator=(const ChannelGuard &) = delete;

    ChannelGuard(ChannelGuard &&) = default;
    ChannelGuard & operator=(ChannelGuard &&) = default;


private:
    std::string m_address;
};

template <class C, class T>
inline ChannelGuard<C, T>::ChannelGuard(
    std::string addr,
    C data,
    std::size_t start,
    std::size_t skip,
    const std::vector<std::uint8_t> & pattern)
    : m_address(std::move(addr))
{
    static_assert(sizeof(T) == 1);

    const int code = ::reserve_recv_channel(
        m_address.c_str(),
        data.data(),
        data.size(),
        start,
        skip,
        pattern.empty() ? nullptr : pattern.data());

    if (code != 0)
    {
        const std::string& msg = std::format(
            "Failed reserve channel with address {}. Error code: {}", m_address, code);
        throw std::runtime_error{ msg };
    }
}

template <class C, class T>
inline ChannelGuard<C, T>::~ChannelGuard()
{
    ::free_recv_channel(m_address.c_str());
}


template <class C>
struct TestCase
{
    std::string addr;
    C data;
    std::size_t sgm_size;
    std::size_t start;
    std::size_t skip;
    std::vector<uint8_t> pattern;

    std::string info(std::size_t res_size) const;
};

using StrTestCase = TestCase<std::string_view>;
using ByteTestCase = TestCase<std::vector<std::uint8_t>>;

template <class C>
std::string TestCase<C>::info(std::size_t res_size) const
{
    const std::string_view direction = start == 0 ? "прямой (0, 1, 2 ...)"
        : (start < data.size() ? "случайный" : "обратный (N, N - 1, N - 2)");

    const std::string_view wait_flag = skip < 2 ? "нет" : "да";
    return std::format(
        R"(
адрес канала                 - {}
размер оригинальных данных   - {}
размер полученных данных     - {}
максимальный размер сегмента - {}
порядок получения сегментов  - {}
требуется ожидание сегментов - {}
)",
        addr, data.size(), res_size, sgm_size, direction, wait_flag);
}

std::vector<std::uint8_t> generate_byte_array(std::size_t size, std::uint32_t seed)
{
    std::vector<std::uint8_t> arr;
    arr.reserve(size);

    std::mt19937 gen(seed);

    for (std::size_t i = 0; i < size; ++i)
        arr.push_back(gen() % std::numeric_limits<std::uint8_t>::max());

    return arr;
}

template <std::size_t N, std::uint32_t S>
std::vector<std::uint8_t> get_byte_array()
{
    static std::vector<std::uint8_t> arr = generate_byte_array(N, S);
    return arr;
}


std::size_t calc_iter_number(std::size_t data_size, std::size_t sgm_size, std::size_t skip)
{
    if (sgm_size == 0)
        return 1;

    const std::size_t without_skip = data_size / sgm_size + (data_size % sgm_size > 0 ? 1 : 0);
    return (skip < 2 ? without_skip : (without_skip * (skip + 1)) / skip) + 1;
}

template <class C>
void simple_test(const TestCase<C> & param)
{
    static_assert(sizeof(typename C::value_type) == 1);

    ChannelGuard guard(param.addr, param.data, param.start, param.skip, param.pattern);
    SegmentReceiver recv(param.addr, param.sgm_size);

    // Ограничиваем количество попыток, чтобы избежать бесконечного цикла
    const std::size_t sgm_size = param.pattern.empty() ? param.sgm_size : param.sgm_size / 2;
    std::size_t recv_count = 2 * calc_iter_number(param.data.size(), sgm_size, param.skip);

    while (recv_count-- > 0)
    {
        std::pair<std::size_t, std::size_t> state = recv.receive_segment();
        if (state.first == state.second)
            break;
    }

    const std::vector<std::uint8_t> & result = recv.merge_segments();

    auto is_equal = [](std::uint8_t left, auto right) -> bool
    {
        return left == static_cast<std::uint8_t>(right);
    };

    const bool ok = result.size() == param.data.size() &&
        std::equal(result.begin(), result.end(), param.data.begin(), is_equal);

    boost::ut::expect(ok) << std::format(
        "\nРезультирующие данные не совпадают с оригинальными. Параметры прогона:{}",
        param.info(result.size()));
}


