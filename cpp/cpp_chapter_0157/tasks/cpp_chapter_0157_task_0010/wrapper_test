import boost.ut;
import std;


struct Pixel
{
    Pixel()
    {
        ++created;
    }

    ~Pixel()
    {
        ++destroyed;
    }

    unsigned char r = 0;
    unsigned char g = 0;
    unsigned char b = 0;

    static std::size_t created;
    static std::size_t destroyed;
};

std::size_t Pixel::created = 0;
std::size_t Pixel::destroyed = 0;

#INJECT-b585472fa

using namespace boost::ut;

int main()
{
    "check Pixel creation & destruction"_test = [] {
        expect(Pixel::created == 0 && Pixel::destroyed == 0) << "Before calling capture_screenshot() no Pixel object must be allocated" << fatal;
        capture_screenshot();
        expect(Pixel::created == 3 && Pixel::destroyed == 3) << "After calling capture_screenshot() 3 Pixel object must be destroyed" << fatal;
    };
}
